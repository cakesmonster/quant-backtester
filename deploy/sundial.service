[Unit]
Description=日晷 Sundial — A股市场数据看板
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.hermes/projects/sundial
ExecStart=/usr/local/lib/hermes-agent/venv/bin/python3 -m uvicorn sundial.main:app --host 127.0.0.1 --port 8200
Restart=always
RestartSec=5
Environment=SUNDIAL_HOST=127.0.0.1
Environment=SUNDIAL_PORT=8200
MemoryMax=600M
CPUQuota=60%

[Install]
WantedBy=multi-user.target
