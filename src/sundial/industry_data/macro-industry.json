    },
    {
      "id": "铅",
      "group": "⛏️原材料",
      "r": 14,
      "summary": "生意社/上期所期货。铅酸电池的命根子——汽车启动电瓶和电动两轮车的电池全靠它。全球铅消费80%以上在电池领域。也是防辐射材料（医院X光室用的铅板就是它）。",
      "futures_code": "pb",
      "society_category": "有色",
      "leaders": []
    },
    {
      "id": "硫酸",
      "group": "⛏️原材料",
      "r": 12,
      "summary": "生意社。化工之母，产量最大的基础化工品。用硫磺或硫铁矿烧出来的。最大的用途是泡磷矿石生产磷酸（湿法磷酸），再往下做成磷肥和磷酸铁锂。也用于金属酸洗和钛白粉生产。",
      "futures_code": null,
      "society_category": "化工",
      "leaders": []
    },
    {
      "id": "纯苯",
      "group": "⛏️原材料",
      "r": 12,
      "summary": "生意社。最基础的芳烃化学品，从石油重整或裂解汽油里提取出来的。苯环结构让它成为染料、医药、农药、塑料、合成橡胶的共同原料。毒性大，管理严格。",
      "futures_code": null,
      "society_category": "化工",
      "leaders": []
    },
    {
      "id": "苯乙烯",
      "group": "⛏️原材料",
      "r": 15,
      "summary": "生意社/大商所期货。苯和乙烯反应做出来的，是聚苯乙烯(PS)、ABS树脂等塑料的核心单体。家电外壳、汽车内饰件、泡沫包装箱都离不开它。上游是石油化工，下游是橡塑制品。",
      "futures_code": "EB",
      "society_category": "化工",
      "leaders": []
    },
    {
      "id": "PX",
      "group": "⛏️原材料",
      "r": 13,
      "summary": "生意社。对二甲苯，从石脑油重整出来的芳烃。PTA的原料——PX加氧气做成PTA，PTA再和乙二醇聚合成聚酯切片，最后纺成涤纶（化纤衣服的面料）。整个聚酯产业链的起点。",
      "futures_code": null,
      "society_category": "化工",
      "leaders": []
    },
    {
      "id": "醋酸",
      "group": "⛏️原材料",
      "r": 11,
      "summary": "生意社。甲醇和一氧化碳合成的有机酸，是醋里的酸味来源（但工业醋酸不能吃）。主要用来生产PTA（做涤纶）、醋酸乙烯（做EVA光伏胶膜）和醋酸酯（做油漆溶剂）。",
      "futures_code": null,
      "society_category": "化工",
      "leaders": []
    },
    {
      "id": "氯化钾",
      "group": "⛏️原材料",
      "r": 12,
      "summary": "生意社。钾肥的核心品种，庄稼需要的三大营养元素（氮磷钾）之一。中国钾资源匮乏，一半以上靠从加拿大、俄罗斯、白俄罗斯进口。盐湖股份在青海察尔汗盐湖是国内最大钾肥产地。",
      "futures_code": null,
      "society_category": "化工",
      "leaders": []
    },
    {
      "id": "磷酸一铵",
      "group": "⛏️原材料",
      "r": 11,
      "summary": "生意社。磷肥的重要品种，用磷酸和氨反应制成。含磷又含氮，水溶性好，是复合肥的核心原料。施到地里让庄稼根系发达、籽粒饱满。国内主产区在湖北和云南的磷矿附近。",
      "futures_code": null,
      "society_category": "化工",
      "leaders": []
    },
    {
      "id": "磷酸二铵",
      "group": "⛏️原材料",
      "r": 12,
      "summary": "生意社。磷肥里的高端品种，含磷量比磷酸一铵还高、水溶性更好。既当基肥也当追肥用，特别适合缺磷的土壤。中国每年大量出口到印度、东南亚等农业大国。",
      "futures_code": null,
      "society_category": "化工",
      "leaders": []
    },
    {
      "id": "PP",
      "group": "⛏️原材料",
      "r": 14,
      "summary": "生意社/大商所期货。聚丙烯，产量最大的通用塑料之一。丙烯聚合出来，又轻又韧又耐热。汽车保险杠、仪表板、家电外壳、外卖餐盒、口罩熔喷布都是它。日用品无处不在。",
      "futures_code": "pp",
      "society_category": "橡塑",
      "leaders": []
    },
    {
      "id": "LLDPE",
      "group": "⛏️原材料",
      "r": 14,
      "summary": "生意社/大商所期货。线性低密度聚乙烯，聚乙烯家族里韧性最好的品种。乙烯聚合出来的，主要做农用地膜（大棚膜）、快递袋、食品保鲜膜。比普通聚乙烯更耐撕裂。",
      "futures_code": "l",
      "society_category": "橡塑",
      "leaders": []
    },
    {
      "id": "PVC",
      "group": "⛏️原材料",
      "r": 14,
      "summary": "生意社/大商所期货。聚氯乙烯，全球用量最大的塑料之一。用电石法或乙烯法生产。硬质PVC做下水管、门窗型材；加了增塑剂变软后做电线电缆绝缘层、人造革。和房地产开工高度相关。",
      "futures_code": "v",
      "society_category": "橡塑",
      "leaders": []
    },
    {
      "id": "PTA",
      "group": "⛏️原材料",
      "r": 16,
      "summary": "生意社/郑商所期货。精对苯二甲酸，PX氧化做出来的白色粉末。和乙二醇反应聚合成聚酯（PET），聚酯纺丝就是涤纶——我们穿的衣服里六成以上是涤纶。中国PTA产能全球第一。",
      "futures_code": "TA",
      "society_category": "纺织",
      "leaders": []
    },
    {
      "id": "皮棉",
      "group": "⛏️原材料",
      "r": 16,
      "summary": "生意社/郑商所期货。轧花厂把地里摘的籽棉去掉棉籽后的棉花，是纺织厂直接用的原料。新疆棉花产量占全国近九成。棉纱、棉布、衣服的第一道原料。和化纤（涤纶）既竞争又互补。",
      "futures_code": "CF",
      "society_category": "纺织",
      "leaders": []
    },
    {
      "id": "涤纶短纤",
      "group": "⛏️原材料",
      "r": 14,
      "summary": "生意社/郑商所期货。把聚酯熔体切成短纤维，像棉花一样蓬松。可以纯纺也可以和棉花混纺（涤棉布），做填充棉、无纺布、缝纫线。是化纤里产量最大的品种，衣服被子的主要面料来源。",
      "futures_code": "PF",
      "society_category": "纺织",
      "leaders": []
    },
    {
      "id": "沥青",
      "group": "⛏️原材料",
      "r": 14,
      "summary": "生意社/上期所期货。原油蒸馏后的最后一道渣，黑乎乎黏糊糊的修路材料。中国90%以上的道路是沥青路面，公路建设旺季（夏秋）沥青需求最旺。也做建筑防水卷材。",
      "futures_code": "bu",
      "society_category": "建材",
      "leaders": []
    },
    {
      "id": "大豆",
      "group": "⛏️原材料",
      "r": 16,
      "summary": "生意社/大商所期货。全球最重要的油料和蛋白来源。进口大豆（主要来自巴西、美国）榨油后80%变成豆粕喂猪养鸡，20%是豆油炒菜用。中国大豆进口量占全球贸易量六成以上，高度依赖进口。",
      "futures_code": "a",
      "society_category": "农副",
      "leaders": []
    },
    {
      "id": "鸡蛋",
      "group": "⛏️原材料",
      "r": 14,
      "summary": "生意社/大商所期货。老百姓餐桌上最便宜的动物蛋白，也是食品工业的基础原料（蛋糕、蛋液、蛋粉）。蛋鸡存栏量和饲料成本（玉米+豆粕）决定了鸡蛋价格。季节性波动明显，中秋国庆前是需求高峰。",
      "futures_code": "jd",
      "society_category": "农副",
      "leaders": []
    },
    {
